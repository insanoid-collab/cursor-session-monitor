{
  "name": "cursor-session-monitor",
  "version": "0.1.0",
  "description": "Cursor hook receiver + session tracker",
  "main": "dist/index.js",
  "type": "commonjs",
  "scripts": {
    "dev": "portless cursor-monitor tsx watch src/index.ts",
    "dev:direct": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "portless cursor-monitor node dist/index.js",
    "start:direct": "node dist/index.js",
    "test": "vitest run",
    "sessions": "tsx scripts/sessions.ts",
    "hooks:install": "node scripts/install-hooks.js",
    "hooks:uninstall": "node scripts/install-hooks.js --uninstall"
  },
  "keywords": [
    "cursor",
    "monitor",
    "fastify",
    "sqlite"
  ],
  "author": "insanoid-agent",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.12.2",
    "better-sqlite3": "^12.4.1",
    "dotenv": "^17.2.3",
    "fastify": "^5.6.1",
    "js-yaml": "^4.1.1",
    "nanoid": "^5.1.6",
    "winston": "^3.18.3",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.3.1",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
